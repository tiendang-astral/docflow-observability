# =============================================================================
# DocFlow Monitor Stack — Environment
# =============================================================================
#
# HƯỚNG DẪN:
#   1. Sao chép: cp .env.example .env
#   2. Điền giá trị thật vào các biến bắt buộc (!)
#   3. TUYỆT ĐỐI KHÔNG commit file này lên git
#
# Khởi động cả 2 stack : ./up.sh
# Chỉ observability    : ./up.sh --observability
# Chỉ ELK              : ./up.sh --elk
# =============================================================================

# ── PostgreSQL — dùng cho postgres-exporter (!) ───────────────────────────────
POSTGRES_DB=docaiplatform
POSTGRES_USER=postgres
POSTGRES_PASSWORD=bd465f15c74a6fde01132f3bc6ef91b9c7ba9ab2

# ── Telegram Alerting (!) ─────────────────────────────────────────────────────
# Lấy bot token từ @BotFather
# Lấy chat_id: https://api.telegram.org/bot<TOKEN>/getUpdates
TELEGRAM_BOT_TOKEN=8658510205:AAHcSqyhCVebpw8JEIcWXCD2MyAOxTn58qY                  # (!) Format: 123456789:ABCdefGhIJKlmNoPQRsTUVwxyZ
TELEGRAM_CHAT_ID=-5145836842

# ── Grafana (!) ───────────────────────────────────────────────────────────────
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=123456

# ── ELK (!) ───────────────────────────────────────────────────────────────────
# Tạo key: openssl rand -hex 16
KIBANA_ENCRYPTION_KEY=3f8c2d1e4b7091f6a2e5d8c3b4f7a1e

# ── Ports ─────────────────────────────────────────────────────────────────────
PROMETHEUS_PORT=29111
GRAFANA_PORT=29112
ALERTMANAGER_PORT=29113
ELASTIC_PORT=29200
KIBANA_PORT=29560

# ── Network names (tuỳ chỉnh nếu cần) ────────────────────────────────────────
DOCFLOW_ELK_NETWORK=docflow-elk
