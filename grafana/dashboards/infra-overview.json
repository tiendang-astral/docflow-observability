    {
      "id": 100,
      "type": "row",
      "title": "API & Infrastructure",
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "panels": []
    },
    {
      "id": 1,
      "type": "stat",
      "title": "CPU usage",
      "description": "Average CPU utilization across all cores. Green < 70%, Yellow 70–85%, Red > 85%.",
      "gridPos": { "h": 3, "w": 5, "x": 0, "y": 1 },
      "datasource": { "type": "prometheus", "uid": "docai-prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "decimals": 1,
          "min": 0,
          "max": 100,
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "#EAB839", "value": 70 },
              { "color": "red", "value": 85 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "colorMode": "background",
        "graphMode": "area",
        "justifyMode": "center",
        "orientation": "auto",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "textMode": "value"
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "docai-prometheus" },
          "expr": "100 - (avg(rate(node_cpu_seconds_total{mode=\"idle\"}[2m])) * 100)",
          "legendFormat": "__auto",
          "refId": "A",
          "instant": true
        }
      ]
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Memory",
      "description": "RAM utilization as % of total. Green < 70%, Yellow 70–85%, Red > 85%.",
      "gridPos": { "h": 3, "w": 5, "x": 5, "y": 1 },
      "datasource": { "type": "prometheus", "uid": "docai-prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "decimals": 1,
          "min": 0,
          "max": 100,
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "#EAB839", "value": 70 },
              { "color": "red", "value": 85 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "colorMode": "background",
        "graphMode": "area",
        "justifyMode": "center",
        "orientation": "auto",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "textMode": "value"
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "docai-prometheus" },
          "expr": "(1 - (node_memory_MemAvailable_bytes / node_memory_MemTotal_bytes)) * 100",
          "legendFormat": "__auto",
          "refId": "A",
          "instant": true
        }
      ]
    },
    {
      "id": 3,
      "type": "stat",
      "title": "P95 latency",
      "description": "95th-percentile HTTP response time (ms). Green < 500ms, Yellow < 2s, Red ≥ 2s.",
      "gridPos": { "h": 3, "w": 5, "x": 10, "y": 1 },
      "datasource": { "type": "prometheus", "uid": "docai-prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "decimals": 0,
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "#EAB839", "value": 500 },
              { "color": "red", "value": 2000 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "colorMode": "background",
        "graphMode": "area",
        "justifyMode": "center",
        "orientation": "auto",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "textMode": "value"
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "docai-prometheus" },
          "expr": "histogram_quantile(0.95, sum(rate(docai_http_request_duration_seconds_bucket[5m])) by (le)) * 1000",
          "legendFormat": "__auto",
          "refId": "A",
          "instant": true
        }
      ]
    },
    {
      "id": 4,
      "type": "stat",
      "title": "Error rate",
      "description": "HTTP 5xx responses as % of all requests. Green < 1%, Yellow < 5%, Red ≥ 5%.",
      "gridPos": { "h": 3, "w": 5, "x": 15, "y": 1 },
      "datasource": { "type": "prometheus", "uid": "docai-prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "decimals": 2,
          "min": 0,
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "#EAB839", "value": 1 },
              { "color": "red", "value": 5 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "colorMode": "background",
        "graphMode": "area",
        "justifyMode": "center",
        "orientation": "auto",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "textMode": "value"
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "docai-prometheus" },
          "expr": "(sum(rate(docai_http_request_duration_seconds_count{status=~\"5..\"}[5m])) / (sum(rate(docai_http_request_duration_seconds_count[5m])) + 0.001)) * 100 or vector(0)",
          "legendFormat": "__auto",
          "refId": "A",
          "instant": true
        }
      ]
    },
    {
      "id": 50,
      "type": "stat",
      "title": "Disk usage",
      "description": "Dung lượng disk đã dùng và tổng dung lượng (loại trừ tmpfs/squashfs).",
      "gridPos": { "h": 3, "w": 4, "x": 20, "y": 1 },
      "datasource": { "type": "prometheus", "uid": "docai-prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "bytes",
          "decimals": 1,
          "min": 0,
          "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }] }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "Used" },
            "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "text" } }]
          },
          {
            "matcher": { "id": "byName", "options": "Total" },
            "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "text" } }]
          }
        ]
      },
      "options": {
        "colorMode": "none",
        "graphMode": "none",
        "justifyMode": "center",
        "orientation": "vertical",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "textMode": "value_and_name"
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "docai-prometheus" },
          "expr": "sum(max without(mountpoint) (node_filesystem_size_bytes{fstype=~\"ext4|xfs|btrfs|zfs\"})) - sum(max without(mountpoint) (node_filesystem_avail_bytes{fstype=~\"ext4|xfs|btrfs|zfs\"}))",
          "legendFormat": "Used",
          "refId": "A",
          "instant": true
        },
        {
          "datasource": { "type": "prometheus", "uid": "docai-prometheus" },
          "expr": "sum(max without(mountpoint) (node_filesystem_size_bytes{fstype=~\"ext4|xfs|btrfs|zfs\"}))",
          "legendFormat": "Total",
          "refId": "B",
          "instant": true
        }
      ]
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "CPU & Memory & Latency & Requests — combined",
      "description": "Trục trái (%): CPU (xanh dương) + RAM (xanh lá). Trục phải (ms): P95 Latency (cam). Cột nền (tím): Requests/s. Đường đỏ nét đứt = ngưỡng 85%.",
      "gridPos": { "h": 10, "w": 24, "x": 0, "y": 4 },
      "datasource": { "type": "prometheus", "uid": "docai-prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 105,
          "decimals": 1,
          "color": { "mode": "palette-classic" },
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 12,
            "gradientMode": "none",
            "showPoints": "never",
            "spanNulls": false,
            "axisPlacement": "left",
            "axisLabel": "CPU / RAM (%)",
            "thresholdsStyle": { "mode": "dashed" }
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "transparent", "value": null },
              { "color": "red", "value": 85 }
            ]
          }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "CPU %" },
            "properties": [
              { "id": "color", "value": { "mode": "fixed", "fixedColor": "#5794F2" } },
              { "id": "custom.fillOpacity", "value": 15 }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "RAM %" },
            "properties": [
              { "id": "color", "value": { "mode": "fixed", "fixedColor": "#73BF69" } },
              { "id": "custom.fillOpacity", "value": 8 }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "P95 Latency (ms)" },
            "properties": [
              { "id": "color", "value": { "mode": "fixed", "fixedColor": "#FF9830" } },
              { "id": "unit", "value": "ms" },
              { "id": "min", "value": 0 },
              { "id": "custom.axisPlacement", "value": "right" },
              { "id": "custom.axisLabel", "value": "Latency (ms)" },
              { "id": "custom.lineWidth", "value": 2 },
              { "id": "custom.fillOpacity", "value": 0 },
              { "id": "custom.thresholdsStyle", "value": { "mode": "off" } }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "Requests/s" },
            "properties": [
              { "id": "color", "value": { "mode": "fixed", "fixedColor": "#8073C4" } },
              { "id": "unit", "value": "reqps" },
              { "id": "min", "value": 0 },
              { "id": "custom.drawStyle", "value": "bars" },
              { "id": "custom.lineWidth", "value": 0 },
              { "id": "custom.fillOpacity", "value": 35 },
              { "id": "custom.axisPlacement", "value": "hidden" },
              { "id": "custom.thresholdsStyle", "value": { "mode": "off" } }
            ]
          }
        ]
      },
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": {
          "displayMode": "table",
          "placement": "bottom",
          "showLegend": true,
          "calcs": ["mean", "max", "lastNotNull"]
        }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "docai-prometheus" },
          "expr": "100 - (avg(rate(node_cpu_seconds_total{mode=\"idle\"}[2m])) * 100)",
          "legendFormat": "CPU %",
          "refId": "A"
        },
        {
          "datasource": { "type": "prometheus", "uid": "docai-prometheus" },
          "expr": "(1 - (node_memory_MemAvailable_bytes / node_memory_MemTotal_bytes)) * 100",
          "legendFormat": "RAM %",
          "refId": "B"
        },
        {
          "datasource": { "type": "prometheus", "uid": "docai-prometheus" },
          "expr": "histogram_quantile(0.95, sum(rate(docai_http_request_duration_seconds_bucket[5m])) by (le)) * 1000",
          "legendFormat": "P95 Latency (ms)",
          "refId": "C"
        },
        {
          "datasource": { "type": "prometheus", "uid": "docai-prometheus" },
          "expr": "sum(rate(docai_http_request_duration_seconds_count[1m]))",
          "legendFormat": "Requests/s",
          "refId": "D"
        }
      ]
    },
